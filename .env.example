# =============================================================================
# Fluvio — Variables de entorno (plantilla)
# Copia este archivo a .env y rellena los valores reales. NUNCA commitees .env.
# [REQUERIDA] = el código no arranca sin ella.  [opcional] = solo en ciertos casos.
# =============================================================================

# ─── Supabase (base de datos + auth) ─────────────────────────────────────────
# Backend Python (apps/api + apps/bot) — usa la service_role key (acceso total).
SUPABASE_URL=https://TU_PROYECTO.supabase.co                 # [REQUERIDA] api + bot
SUPABASE_SERVICE_ROLE_KEY=tu_service_role_key_aqui           # [REQUERIDA] api + bot

# Validación de JWT en la API (claim business_id). Project Settings → API → JWT Secret.
SUPABASE_JWT_SECRET=tu_jwt_secret_de_supabase                # [REQUERIDA] apps/api (auth)

# Frontend Next.js (apps/web) — claves PÚBLICAS (se exponen al navegador).
NEXT_PUBLIC_SUPABASE_URL=https://TU_PROYECTO.supabase.co     # [REQUERIDA] apps/web
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=tu_publishable_key_aqui # [REQUERIDA] apps/web

# ─── WhatsApp Cloud API (oficial — para escalar a múltiples restaurantes) ────
WHATSAPP_TOKEN=tu_token_de_acceso_permanente                 # [REQUERIDA] envío de mensajes
WHATSAPP_VERIFY_TOKEN=una_cadena_secreta_que_tu_eliges       # [REQUERIDA] verificación del webhook
WHATSAPP_PHONE_NUMBER_ID=tu_phone_number_id                  # [opcional] referencia setup Cloud API
WHATSAPP_BUSINESS_ACCOUNT_ID=tu_business_account_id          # [opcional] referencia setup Cloud API

# ─── Meta App (Embedded Signup + firma del webhook) ──────────────────────────
# META_APP_SECRET valida la firma X-Hub-Signature-256 de cada POST al webhook
# del bot Y el intercambio de código del Embedded Signup en el API.
# Sin él, el webhook acepta mensajes sin autenticar (solo permitido en dev).
META_APP_ID=tu_app_id_de_meta                                # [REQUERIDA] api (Embedded Signup)
META_APP_SECRET=tu_app_secret_de_meta                        # [REQUERIDA] api + bot (firma webhook)
NEXT_PUBLIC_META_APP_ID=tu_app_id_de_meta                    # [REQUERIDA] apps/web (popup signup)
NEXT_PUBLIC_META_CONFIG_ID=tu_config_id_de_embedded_signup   # [REQUERIDA] apps/web (popup signup)

# ─── Anthropic / Claude (cerebro del bot) ────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...                                 # [REQUERIDA] apps/bot

# ─── Baileys Bridge (puente WhatsApp temporal vía QR — Node) ─────────────────
# Mientras Duble use Baileys. DUBLE_PHONE_NUMBER_ID debe coincidir con el campo
# `telefono_whatsapp` del renglón de Duble en la tabla businesses.
DUBLE_PHONE_NUMBER_ID=duble-baileys                          # [REQUERIDA] bridge Baileys
BOT_API_URL=http://localhost:8001                            # [REQUERIDA] bridge → bot Python

# ─── Jobs internos ───────────────────────────────────────────────────────────
# Secreto que debe enviar el cron externo en el header x-internal-secret
# para disparar POST /internal/noshow/run.
INTERNAL_JOB_SECRET=una_cadena_secreta_para_el_cron          # [REQUERIDA] job nocturno no-show

# ─── EasyPanel — control del bot desde el dashboard ─────────────────────────
# Permite iniciar/reiniciar/detener el servicio bot desde /dashboard/chatbot.
# Obtén el token en EasyPanel → Settings → API Tokens.
EASYPANEL_URL=https://panel.tu-dominio.com                   # [opcional] URL de tu instancia EasyPanel
EASYPANEL_API_TOKEN=tu_api_token_de_easypanel                # [opcional] API token (Settings → API)
EASYPANEL_PROJECT=fluvio                                     # [opcional] nombre del proyecto en EasyPanel
EASYPANEL_BOT_SERVICE=bot                                    # [opcional] nombre del servicio bot (default: bot)
BOT_INTERNAL_URL=http://bot:8000                             # [opcional] URL interna del bot para health check (default: http://bot:8000)

# ─── App / URLs ──────────────────────────────────────────────────────────────
ENVIRONMENT=development                                      # development | staging | production
NEXT_PUBLIC_API_URL=http://localhost:8000                    # URL pública de apps/api (también define CORS en la API)
API_URL=http://localhost:8000                                # [opcional] URL interna de la API
